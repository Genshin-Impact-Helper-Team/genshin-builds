---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WeaponBrowser from '../components/WeaponBrowser.astro';
import '../styles/base.css';
import '../styles/home.css';
import '../styles/theme.css';
import '../styles/weapons.css';
import { t } from '../utils/i18n';
import { sitePath } from '../utils/paths';
import { getWeaponBrowserData } from '../utils/weapon-browser';

const data = getWeaponBrowserData('en');
const { locale } = data;
const title = t(locale, 'ui', 'Weapons');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang="en" page="weapons" />
    <main class="weapon-page">
      <h1>{title}</h1>
      <WeaponBrowser data={data} locale={locale} />
    </main>
    <Footer lang="en" />
  </body>
</html>
