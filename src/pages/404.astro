---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NotFoundContent from '../components/NotFoundContent.astro';
import '../styles/base.css';
import '../styles/home.css';
import '../styles/theme.css';
import { getLocale, t } from '../utils/i18n';
import { sitePath } from '../utils/paths';

const locale = getLocale('en');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{t(locale, 'ui', 'Page Not Found')} - Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang="en" />
    <NotFoundContent locale={locale} lang="en" detectLanguage />
    <Footer lang="en" />
  </body>
</html>
