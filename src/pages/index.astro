---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HomeFilters from '../components/HomeFilters.astro';
import { Image } from 'astro:assets';
import '../styles/base.css';
import '../styles/build.css';
import '../styles/home.css';
import '../styles/theme.css';
import { getHomePageData } from '../utils/home-page';
import { t } from '../utils/i18n';
import { localizedPath, sitePath } from '../utils/paths';

const { characters, locale } = getHomePageData('en');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang="en" />
    <main class="home-page">
      <h1>Genshin Builds</h1>
      <p class="home-intro">
        {t(locale, 'ui', 'Home source intro before link')}{' '}
        <a
          href="https://docs.google.com/spreadsheets/u/1/d/e/2PACX-1vRq-sQxkvdbvaJtQAGG6iVz2q2UN9FCKZ8Mkyis87QHFptcOU3ViLh0_PJyMxFSgwJZrd10kbYpQFl1/pubhtml#gid=2001372201"
          >{t(locale, 'ui', 'GI Helper Team builds doc')}</a
        >{' '}
        {t(locale, 'ui', 'Home source intro after link')}
      </p>
      <HomeFilters locale={locale} />

      {/* The client-side filter script reads these data attributes. */}
      <div class="character-grid">
        {
          characters.map((character, index) => (
            <a
              class={`character-card ${character.element}`}
              href={localizedPath('en', character.slug)}
              aria-label={`Open ${character.name} builds`}
              data-character-card
              data-element={character.element}
              data-name={character.name}
              data-rarity={character.rarity}
              data-weapon={character.weapon}
            >
              <Image
                src={character.portrait}
                alt={`${character.name} portrait`}
                loading={index < 12 ? 'eager' : 'lazy'}
                width="72"
                height="72"
              />
              <span>{character.name}</span>
            </a>
          ))
        }
      </div>
    </main>
    <Footer lang="en" />
    <script>
      import '../scripts/character-filters';
    </script>
  </body>
</html>
