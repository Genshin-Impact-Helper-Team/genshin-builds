---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HomeFilters from '../components/HomeFilters.astro';
import HomeRoster from '../components/HomeRoster.astro';
import '../styles/base.css';
import '../styles/home.css';
import '../styles/theme.css';
import { getHomePageData } from '../utils/home-page';
import { t } from '../utils/i18n';
import { sitePath } from '../utils/paths';

const { characters, locale } = getHomePageData('en');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang="en" />
    <main class="home-page">
      <h1>Genshin Builds</h1>
      <p class="home-intro">
        {t(locale, 'ui', 'Home source intro before link')}{' '}
        <a
          href="https://docs.google.com/spreadsheets/u/1/d/e/2PACX-1vRq-sQxkvdbvaJtQAGG6iVz2q2UN9FCKZ8Mkyis87QHFptcOU3ViLh0_PJyMxFSgwJZrd10kbYpQFl1/pubhtml#gid=2001372201"
          >{t(locale, 'ui', 'GI Helper Team builds doc')}</a
        >{' '}
        {t(locale, 'ui', 'Home source intro after link')}
      </p>
      <HomeFilters locale={locale} />
      <HomeRoster characters={characters} locale={locale} lang="en" />
    </main>
    <Footer lang="en" />
    <script>
      import '../scripts/character-filters';
    </script>
  </body>
</html>
