---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HomeFilters from '../components/HomeFilters.astro';
import HomeRoster from '../components/HomeRoster.astro';
import '../styles/base.css';
import '../styles/home.css';
import '../styles/theme.css';
import { getHomePageData } from '../utils/home-page';
import { t } from '../utils/i18n';
import { sitePath } from '../utils/paths';

const { characters, latestVersion, locale, recentlyUpdatedCharacters } =
  getHomePageData('en');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang="en" />
    <main class="home-page">
      <h1>THIS IS A TEST CAN YOU SEE IT</h1>
      <p class="home-disclaimer">
        {t(locale, 'ui', 'Home translation disclaimer', undefined, false)}
      </p>
      <HomeFilters
        latestVersion={latestVersion}
        locale={locale}
        recentlyUpdatedCount={recentlyUpdatedCharacters.length}
      />
      <HomeRoster characters={characters} locale={locale} lang="en" />
    </main>
    <Footer lang="en" />
    <script>
      import '../scripts/character-filters';
    </script>
  </body>
</html>
