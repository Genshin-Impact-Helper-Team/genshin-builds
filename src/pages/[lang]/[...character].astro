---
import Weapon from '../../components/Weapon.astro';
import Artifact from '../../components/Artifact.astro';
import Talent from '../../components/Talent.astro';
import Notes from '../../components/Notes.astro';
import CharacterPageLayout from '../../layouts/CharacterLayout.astro';
import { getCharacterPageData } from '../../utils/character-page';
import { t } from '../../utils/i18n';
import { getCharacterStaticPaths } from '../../utils/routes';

export const getStaticPaths = getCharacterStaticPaths;

const { lang, character: characterPath } = Astro.params;
// Server-side loader resolves content JSON into translated, display-ready data.
const {
  characterSlug,
  characterName,
  metadata,
  element,
  lang: currentLang,
  locale,
  builds,
  warnings,
} = getCharacterPageData({ lang, characterPath });

const defaultBuildSlug =
  builds.find((build) => build.isBest)?.slug ?? builds[0]?.slug;

const buildHasItemNotes = (notes: any) =>
  [
    notes?.weapons?.items,
    notes?.artifacts?.sets,
    notes?.artifacts?.mainstats,
    notes?.artifacts?.substats,
    notes?.talents?.items,
  ].some((items) => Array.isArray(items) && items.length > 0);

const noteMarkerExplanation = t(
  locale,
  'ui',
  'Note marker explanation',
  undefined,
  false,
);
---

<CharacterPageLayout
  characterSlug={characterSlug}
  character={characterName}
  metadata={metadata}
  element={element}
  lang={currentLang}
  locale={locale}
>
  <div class="character-builds-layout" data-default-build={defaultBuildSlug}>
    <div class="build-list">
      {
        builds.map((build) => {
          const buildContentId = `build-content-${build.slug}`;
          const hasNoteMarkerHint = buildHasItemNotes(build.notes);

          return (
            <div class="build-card" data-id={build.slug}>
              <button
                class="build-header"
                aria-expanded="false"
                aria-controls={buildContentId}
              >
                <span class="build-title">{build.name}</span>
                {build.isBest && (
                  <span class="build-badge">
                    {t(locale, 'ui', 'Best Role')}
                  </span>
                )}
              </button>

              <div class="build-content" id={buildContentId} hidden aria-hidden="true">
                {hasNoteMarkerHint && (
                  <div class="build-note-hint">
                    <span class="note-marker-text" aria-hidden="true">
                      ⓘ
                    </span>
                    <span>{noteMarkerExplanation}</span>
                  </div>
                )}

                <div class="grid">
                  <Weapon
                    weapons={build.weapons}
                    locale={locale}
                    lang={currentLang}
                  />
                  <Artifact
                    artifacts={build.artifacts}
                    locale={locale}
                    lang={currentLang}
                  />
                  <Talent talents={build.talents} locale={locale} />
                </div>
                <Notes
                  notes={build.notes}
                  buildNote={build.buildNote}
                  locale={locale}
                />
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</CharacterPageLayout>

{
  /* Forward missing translation warnings to the browser console for authors. */
  import.meta.env.DEV && warnings.length > 0 ? (
    <script
      is:inline
      set:html={`const warnings = ${JSON.stringify(warnings)}; warnings.forEach((warning) => console.warn(warning));`}
    />
  ) : null
}

<script>
  import '../../scripts/build-accordion';
  import '../../scripts/note-highlight';
</script>
