---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HomeFilters from '../../components/HomeFilters.astro';
import HomeRoster from '../../components/HomeRoster.astro';
import changelog from '../../content/site/changelog.json';
import '../../styles/base.css';
import '../../styles/home.css';
import '../../styles/theme.css';
import { getHomePageData } from '../../utils/home-page';
import { t } from '../../utils/i18n';
import { localizedPath, sitePath } from '../../utils/paths';
import { getLanguageStaticPaths } from '../../utils/routes';

export const getStaticPaths = getLanguageStaticPaths;

const requestedLang = Array.isArray(Astro.params.lang)
  ? Astro.params.lang[0]
  : Astro.params.lang;
const {
  characters,
  lang,
  locale,
  recentlyUpdatedCharacters,
} = getHomePageData(requestedLang ?? 'en');
const latestChangelogEntry = changelog.groups[0]?.entries?.[0];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Genshin Builds</title>
  </head>
  <body data-element="base">
    <Header locale={locale} lang={lang} />
    <main class="home-page">
      <h1>Genshin Builds</h1>
      <p class="home-disclaimer">
        {t(locale, 'ui', 'Home translation disclaimer', undefined, false)}
      </p>
      {
        latestChangelogEntry?.changes && (
          <a
            class="home-last-update"
            href={localizedPath(lang, 'changelog')}
          >
            <h2>
              {t(locale, 'ui', 'Last Updated', undefined, false)}
            </h2>
            <p class="home-last-update-change">
              {latestChangelogEntry.changes}
            </p>
            <p class="home-last-update-meta">
              <time>{latestChangelogEntry.date}</time>
              {latestChangelogEntry.appliedBy && (
                <span>Applied by {latestChangelogEntry.appliedBy}</span>
              )}
            </p>
          </a>
        )
      }
      <HomeFilters
        locale={locale}
        recentlyUpdatedCount={recentlyUpdatedCharacters.length}
      />
      <HomeRoster characters={characters} locale={locale} lang={lang} />
    </main>
    <Footer lang={lang} />
    <script>
      import '../../scripts/card-filters';
    </script>
  </body>
</html>
