---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NotFoundContent from '../../components/NotFoundContent.astro';
import '../../styles/base.css';
import '../../styles/home.css';
import '../../styles/theme.css';
import { getLocale, t } from '../../utils/i18n';
import { sitePath } from '../../utils/paths';
import { getLanguageStaticPaths } from '../../utils/routes';

export const getStaticPaths = getLanguageStaticPaths;

const requestedLang = Array.isArray(Astro.params.lang)
  ? Astro.params.lang[0]
  : Astro.params.lang;
const lang = requestedLang ?? 'en';
const locale = getLocale(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{t(locale, 'ui', 'Page Not Found')} - Genshin Builds</title>
  </head>
  <body data-element="anemo">
    <Header locale={locale} lang={lang} />
    <NotFoundContent locale={locale} lang={lang} />
    <Footer lang={lang} />
  </body>
</html>
