---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArtifactSetBrowser from '../../components/ArtifactSetBrowser.astro';
import '../../styles/base.css';
import '../../styles/home.css';
import '../../styles/theme.css';
import '../../styles/artifact-sets.css';
import { t } from '../../utils/i18n';
import { sitePath } from '../../utils/paths';
import { getLanguageStaticPaths } from '../../utils/routes';
import { getArtifactSetBrowserData } from '../../utils/artifact-browser';

export const getStaticPaths = getLanguageStaticPaths;

const lang = Array.isArray(Astro.params.lang)
  ? Astro.params.lang[0]
  : Astro.params.lang;
const data = getArtifactSetBrowserData(lang ?? 'en');
const { locale } = data;
const title = `${t(locale, 'ui', 'Artifacts')} ${t(locale, 'ui', 'Sets')}`;
---

<html lang={data.lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href={sitePath('favicon.webp')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Genshin Builds</title>
  </head>
  <body data-element="base">
    <Header locale={locale} lang={data.lang} page="artifacts" />
    <main class="artifact-set-page">
      <h1>{title}</h1>
      <ArtifactSetBrowser data={data} locale={locale} />
    </main>
    <Footer lang={data.lang} />
  </body>
</html>
