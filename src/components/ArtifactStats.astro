---
import { t } from '../utils/i18n';
import InlineNoteLabel from './InlineNoteLabel.astro';

type StatItem = {
  name: string;
  note?: string;
  noteId?: string;
};

type SubstatPriority = StatItem | { items: StatItem[] };

type ArtifactRecommendations = {
  mainstats?: {
    main_stats: {
      sands: StatItem[];
      goblet: StatItem[];
      circlet: StatItem[];
    };
  };
  substats?: {
    substats_priority: SubstatPriority[];
  };
};

const { artifacts, locale } = Astro.props as {
  artifacts: ArtifactRecommendations;
  locale: any;
};

const hasNoteMarker = (item: StatItem) => item.noteId || item.note;

const mainStatSlots = [
  { label: 'Sands', items: artifacts.mainstats?.main_stats.sands ?? [] },
  { label: 'Goblet', items: artifacts.mainstats?.main_stats.goblet ?? [] },
  { label: 'Circlet', items: artifacts.mainstats?.main_stats.circlet ?? [] },
].filter((slot) => slot.items.length > 0);

const substatRows = (artifacts.substats?.substats_priority ?? []).map(
  (priority: SubstatPriority, index: number) => ({
    rank: index + 1,
    items: 'items' in priority ? priority.items : [priority],
    hasAlternatives: 'items' in priority,
  }),
);
---

<div class="card recommendation-card artifact-stats-card">
  <h2>{t(locale, 'ui', 'Artifact Stats', undefined, false)}</h2>

  <div class="recommendation-card-body">
    {
      mainStatSlots.length > 0 && (
        <div class="section recommendation-section">
          <h3>{t(locale, 'ui', 'Main Stats')}</h3>

          <div class="stat-grid">
            {mainStatSlots.map((slot) => (
              <div class="stat-row">
                <strong>{t(locale, 'ui', slot.label)}</strong>
                <span>
                  {slot.items.map((stat: StatItem, statIndex: number) => (
                    <>
                      {statIndex > 0 && ' / '}
                      <InlineNoteLabel
                        label={stat.name}
                        noteId={stat.noteId}
                        hasNote={Boolean(hasNoteMarker(stat))}
                        emphasized
                      />
                    </>
                  ))}
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }

    {
      substatRows.length > 0 && (
        <div class="section recommendation-section">
          <h3>{t(locale, 'ui', 'Substats')}</h3>

          <div class="rank-list">
            {substatRows.map((row) => (
              <div class="rank-group">
                {row.items[0] && (
                  <div class="rank-row">
                    <strong class="rank-number">{row.rank}</strong>
                    <span class="rank-content">
                      <InlineNoteLabel
                        label={row.items[0].name}
                        noteId={row.items[0].noteId}
                        hasNote={Boolean(hasNoteMarker(row.items[0]))}
                        emphasized
                      />
                    </span>
                  </div>
                )}

                {row.hasAlternatives &&
                  row.items.slice(1).map((item) => (
                    <div class="rank-row alt">
                      <span class="rank-approx">&asymp;</span>
                      <span class="rank-content">
                        <InlineNoteLabel
                          label={item.name}
                          noteId={item.noteId}
                          hasNote={Boolean(hasNoteMarker(item))}
                          emphasized
                        />
                      </span>
                    </div>
                  ))}
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</div>
