---
import WeaponInfoPopover from './WeaponInfoPopover.astro';
import { t } from '../utils/i18n';
import type {
  WeaponPassiveText,
  WeaponPassiveValue,
} from '../utils/weapon-passive';

type WeaponItem = {
  id?: string;
  name: string;
  rarity: number;
  info?: {
    rarity: number;
    passive?: WeaponPassiveText;
    r1?: WeaponPassiveValue[];
    r2?: WeaponPassiveValue[];
    r3?: WeaponPassiveValue[];
    r4?: WeaponPassiveValue[];
    r5?: WeaponPassiveValue[];
    substat?: string;
    level_1?: {
      base_attack?: number;
      substat_value?: string;
    };
    level_max?: {
      base_attack?: number;
      substat_value?: string;
    };
  };
  refinement?: number | string;
  note?: string;
  noteId?: string;
};

type WeaponRank = {
  items: WeaponItem[];
};

type WeaponRecommendations = {
  weapons: WeaponRank[];
  conditional?: WeaponItem[];
};

const {
  weapons,
  locale,
  lang = 'en',
} = Astro.props as {
  weapons: WeaponRecommendations;
  locale: any;
  lang?: string;
};

/**
 * Formats a refinement value for display beside a weapon name.
 *
 * @param refinement Optional weapon refinement value.
 * @returns Formatted refinement suffix.
 */
const formatRefinement = (refinement?: number | string) =>
  refinement ? ` [R${refinement}]` : '';

const hasNoteMarker = (item: WeaponItem) => item.noteId || item.note;
const conditionalWeapons = weapons.conditional ?? [];
const rankedWeaponGroups = weapons.weapons.map(
  (position: WeaponRank, index: number) => ({
    rank: index + 1,
    rows: position.items.map((weapon, weaponIndex) => ({
      weapon,
      isAlternative: weaponIndex > 0,
    })),
  }),
);
---

<div class="card weapon-card">
  <h2>{t(locale, 'ui', 'Weapons')}</h2>

  {
    /* Ranked weapon groups. Extra items in one rank render as approximate ties. */
  }
  {
    rankedWeaponGroups.map((position) => (
      <div style="margin-bottom: 10px;">
        {position.rows.map(({ weapon, isAlternative }) => {
          const content = (
            <span class="inline-info-label">
              <WeaponInfoPopover weapon={weapon} locale={locale} lang={lang} />
              <span class="bold">
                ({weapon.rarity}
                {'\u2605'}){formatRefinement(weapon.refinement)}
                {weapon.noteId ? (
                  <a class="note-link" href={`#${weapon.noteId}`}>
                    *
                  </a>
                ) : hasNoteMarker(weapon) ? (
                  '*'
                ) : (
                  ''
                )}
              </span>
            </span>
          );

          return isAlternative ? (
            <div class="alt">&asymp; {content}</div>
          ) : (
            <div>
              <strong class="accent-text">{position.rank}.</strong>&#8239;
              {content}
            </div>
          );
        })}
      </div>
    ))
  }

  {/* Optional unranked recommendations that depend on build notes. */}
  {
    conditionalWeapons.length > 0 && (
      <div style="margin-top: 14px;">
        <div class="bold">{t(locale, 'ui', 'Conditional (See Notes):')}</div>

        {conditionalWeapons.map((weapon: WeaponItem) => (
          <div>
            <span class="inline-info-label">
              <WeaponInfoPopover weapon={weapon} locale={locale} lang={lang} />
              <span class="bold">
                ({weapon.rarity}
                {'\u2605'}){formatRefinement(weapon.refinement)}
                {weapon.noteId ? (
                  <a class="note-link" href={`#${weapon.noteId}`}>
                    *
                  </a>
                ) : hasNoteMarker(weapon) ? (
                  '*'
                ) : (
                  ''
                )}
              </span>
            </span>
          </div>
        ))}
      </div>
    )
  }
</div>

<script>
  import '../scripts/info-popover';
</script>
