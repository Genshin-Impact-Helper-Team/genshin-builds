---
import { t } from '../utils/i18n';
const { weapons, locale } = Astro.props;

type WeaponItem = {
  name: string;
  rarity: number;
  refinement?: number | string;
  note?: string;
  noteId?: string;
};

/**
 * Formats a refinement value for display beside a weapon name.
 *
 * @param refinement Optional weapon refinement value.
 * @returns Formatted refinement suffix.
 */
const formatRefinement = (refinement?: number | string) =>
  refinement ? ` [R${refinement}]` : '';
---

<div class="card">
  <h2>{t(locale, 'ui', 'Weapons')}</h2>

  {
    /* Ranked weapon groups. Extra items in one rank render as approximate ties. */
  }
  {
    weapons.weapons.map((position: { items: WeaponItem[] }, i: number) => (
      <div style="margin-bottom: 10px;">
        <div>
          <strong>{i + 1}.</strong>{' '}
          {position.items[0] && (
            <span>
              {position.items[0].name}{' '}
              <span class="bold">
                ({position.items[0].rarity}&#10025;)
                {formatRefinement(position.items[0].refinement)}
                {position.items[0].noteId ? (
                  <a class="note-link" href={`#${position.items[0].noteId}`}>
                    *
                  </a>
                ) : position.items[0].note ? (
                  '*'
                ) : (
                  ''
                )}
              </span>
            </span>
          )}
        </div>

        {position.items.slice(1).map((weapon) => (
          <div class="alt">
            &asymp; {weapon.name}{' '}
            <span class="bold">
              ({weapon.rarity}&#10025;)
              {formatRefinement(weapon.refinement)}
              {weapon.noteId ? (
                <a class="note-link" href={`#${weapon.noteId}`}>
                  *
                </a>
              ) : weapon.note ? (
                '*'
              ) : (
                ''
              )}
            </span>
          </div>
        ))}
      </div>
    ))
  }

  {/* Optional unranked recommendations that depend on build notes. */}
  {
    weapons.conditional?.length > 0 && (
      <div style="margin-top: 14px;">
        <div class="bold">{t(locale, 'ui', 'Conditional (See Notes):')}</div>

        {weapons.conditional.map((weapon: WeaponItem) => (
          <div>
            {weapon.name}{' '}
            <span class="bold">
              ({weapon.rarity}&#10025;)
              {formatRefinement(weapon.refinement)}
              {weapon.noteId ? (
                <a class="note-link" href={`#${weapon.noteId}`}>
                  *
                </a>
              ) : weapon.note ? (
                '*'
              ) : (
                ''
              )}
            </span>
          </div>
        ))}
      </div>
    )
  }
</div>
