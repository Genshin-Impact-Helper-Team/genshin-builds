---
import WeaponInfoPopover from './WeaponInfoPopover.astro';
import { t } from '../utils/i18n';
import type {
  WeaponPassiveText,
  WeaponPassiveValue,
} from '../utils/weapon-passive';
const { weapons, locale, lang = 'en' } = Astro.props;

type WeaponItem = {
  name: string;
  rarity: number;
  info?: {
    rarity: number;
    passive?: WeaponPassiveText;
    r1?: WeaponPassiveValue[];
    r2?: WeaponPassiveValue[];
    r3?: WeaponPassiveValue[];
    r4?: WeaponPassiveValue[];
    r5?: WeaponPassiveValue[];
    substat?: string;
    level_1?: {
      base_attack?: number;
      substat_value?: string;
    };
  };
  level_max?: {
    base_attack?: number;
    substat_value?: string;
  };
  refinement?: number | string;
  note?: string;
  noteId?: string;
};

/**
 * Formats a refinement value for display beside a weapon name.
 *
 * @param refinement Optional weapon refinement value.
 * @returns Formatted refinement suffix.
 */
const formatRefinement = (refinement?: number | string) =>
  refinement ? ` [R${refinement}]` : '';
---

<div class="card weapon-card">
  <h2>{t(locale, 'ui', 'Weapons')}</h2>

  {
    /* Ranked weapon groups. Extra items in one rank render as approximate ties. */
  }
  {
    weapons.weapons.map((position: { items: WeaponItem[] }, i: number) => (
      <div style="margin-bottom: 10px;">
        <div>
          <strong>{i + 1}.</strong>&nbsp;
          {position.items[0] && (
            <span>
              <WeaponInfoPopover
                weapon={position.items[0]}
                locale={locale}
                lang={lang}
              />
              &nbsp;
              <span class="bold">
                ({position.items[0].rarity} {'\u2605'})
                {formatRefinement(position.items[0].refinement)}
                {position.items[0].noteId ? (
                  <a class="note-link" href={`#${position.items[0].noteId}`}>
                    *
                  </a>
                ) : position.items[0].note ? (
                  '*'
                ) : (
                  ''
                )}
              </span>
            </span>
          )}
        </div>

        {position.items.slice(1).map((weapon) => (
          <div class="alt">
            &asymp;{' '}
            <WeaponInfoPopover weapon={weapon} locale={locale} lang={lang} />
            &nbsp;
            <span class="bold">
              ({weapon.rarity} {'\u2605'}){formatRefinement(weapon.refinement)}
              {weapon.noteId ? (
                <a class="note-link" href={`#${weapon.noteId}`}>
                  *
                </a>
              ) : weapon.note ? (
                '*'
              ) : (
                ''
              )}
            </span>
          </div>
        ))}
      </div>
    ))
  }

  {/* Optional unranked recommendations that depend on build notes. */}
  {
    weapons.conditional?.length > 0 && (
      <div style="margin-top: 14px;">
        <div class="bold">{t(locale, 'ui', 'Conditional (See Notes):')}</div>

        {weapons.conditional.map((weapon: WeaponItem) => (
          <div>
            <WeaponInfoPopover weapon={weapon} locale={locale} lang={lang} />
            &nbsp;
            <span class="bold">
              ({weapon.rarity} {'\u2605'}){formatRefinement(weapon.refinement)}
              {weapon.noteId ? (
                <a class="note-link" href={`#${weapon.noteId}`}>
                  *
                </a>
              ) : weapon.note ? (
                '*'
              ) : (
                ''
              )}
            </span>
          </div>
        ))}
      </div>
    )
  }
</div>

<script>
  import '../scripts/weapon-popover';
</script>
