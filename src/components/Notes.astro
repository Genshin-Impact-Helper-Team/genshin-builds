---
import { t } from '../utils/i18n';
const { notes, buildNote, locale } = Astro.props;

type CalculationCredit = {
  author?: string;
  link?: string;
  detail?: string;
};

type NoteItem = {
  keys: string[];
  label: string;
  linkText: string;
};

type RenderedNote = {
  id: string;
  name: string;
  note: string;
};

type NoteGroup = {
  headingId?: string;
  items: RenderedNote[];
};

type NoteSection = {
  headingId: string;
  global: string[];
  groups: NoteGroup[];
};

/**
 * Normalizes one or many calculation credits into valid linked credits.
 */
const toCalculationCredits = (value: CalculationCredit | CalculationCredit[]) =>
  (Array.isArray(value) ? value : [value]).filter(
    (credit) => credit?.author && credit?.link,
  );

/**
 * Collects all calculation credits that belong to one note section.
 */
const getCalculationCredits = (item: NoteItem) =>
  item.keys.flatMap((key) => toCalculationCredits(buildNote?.[key] ?? []));

/**
 * Checks whether a note section has any global notes or item notes.
 */
const hasNoteContent = (section: NoteSection) =>
  section.global.length +
    section.groups.reduce((total, group) => total + group.items.length, 0) >
  0;

// Detailed calculation links use slightly different keys than their UI labels.
const noteItems: NoteItem[] = [
  {
    keys: ['artifact', 'artifacts'],
    label: t(locale, 'ui', 'Artifacts'),
    linkText: t(locale, 'ui', 'Detailed artifacts calculation'),
  },
  {
    keys: ['weapons'],
    label: t(locale, 'ui', 'Weapons'),
    linkText: t(locale, 'ui', 'Detailed weapons calculation'),
  },
  {
    keys: ['talent', 'talents'],
    label: t(locale, 'ui', 'Talents'),
    linkText: t(locale, 'ui', 'Detailed talents calculation'),
  },
  {
    keys: ['global'],
    label: t(locale, 'ui', 'General'),
    linkText: t(locale, 'ui', 'Detailed calculations'),
  },
];

const calculationCreditItems = buildNote
  ? noteItems.flatMap((item) =>
      getCalculationCredits(item).map((credit) => ({ ...item, credit })),
    )
  : [];

const noteSections: NoteSection[] = [
  {
    headingId: 'Regarding Weapons Choices:',
    global: notes.weapons.global,
    groups: [{ items: notes.weapons.items }],
  },
  {
    headingId: 'Regarding Artifacts Choices:',
    global: notes.artifacts.global,
    groups: [
      { headingId: 'Sets', items: notes.artifacts.sets },
      { headingId: 'Main Stats', items: notes.artifacts.mainstats },
      { headingId: 'Substats', items: notes.artifacts.substats },
    ],
  },
  {
    headingId: 'Regarding Talents Choices:',
    global: notes.talents.global,
    groups: [{ items: notes.talents.items }],
  },
].filter(hasNoteContent);

const hasNotes = noteSections.length > 0;
---

{
  (hasNotes ||
    calculationCreditItems.length > 0 ||
    buildNote?.notes?.length > 0) && (
    <div class="card notes-card">
      <h2>{t(locale, 'ui', 'Notes')}</h2>

      {buildNote && (
        <div>
          {/* Optional external calculation links credited in build-notes.json. */}
          {calculationCreditItems.map(({ linkText, credit }) => (
            <div>
              <a href={credit.link} target="_blank">
                {linkText}
              </a>
              {credit.detail && (
                <>
                  {' '}
                  (<span set:html={credit.detail} />)
                </>
              )}{' '}
              - {t(locale, 'ui', 'Thank you to')}
              {'\u00a0'}
              {credit.author}!
            </div>
          ))}

          {buildNote.notes?.length > 0 && (
            <div>
              {/* Build-level editorial notes are already localized and rendered. */}
              {buildNote.notes.map((note: string) => (
                <div set:html={note} />
              ))}
            </div>
          )}
        </div>
      )}

      {noteSections.map((section) => (
        <div>
          <h3>{t(locale, 'ui', section.headingId)}</h3>

          {section.global.map((note) => (
            <p set:html={note} />
          ))}

          {section.groups
            .filter((group) => group.items.length > 0)
            .map((group) => (
              <div>
                {group.headingId && <h4>{t(locale, 'ui', group.headingId)}</h4>}
                {group.items.map((note) => (
                  <div
                    id={note.id}
                    class="note-target"
                    set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
                  />
                ))}
              </div>
            ))}
        </div>
      ))}
    </div>
  )
}
