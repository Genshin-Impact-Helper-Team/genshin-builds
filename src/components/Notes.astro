---
import { t } from '../utils/i18n';
const { notes, buildNote, locale } = Astro.props;

// Compute section visibility up front so empty note cards are skipped entirely.
const hasWeaponsNotes =
  notes.weapons.global.length + notes.weapons.items.length > 0;
const hasArtifactNotes =
  notes.artifacts.global.length +
    notes.artifacts.sets.length +
    notes.artifacts.mainstats.length +
    notes.artifacts.substats.length >
  0;
const hasTalentNotes =
  notes.talents.global.length + notes.talents.items.length > 0;
const hasNotes = hasWeaponsNotes || hasArtifactNotes || hasTalentNotes;

// Detailed calculation links use slightly different keys than their UI labels.
const noteItems = [
  {
    key: 'artifact',
    label: t(locale, 'ui', 'Artifacts'),
    linkText: t(locale, 'ui', 'Detailed artifacts calculation'),
  },
  {
    key: 'weapons',
    label: t(locale, 'ui', 'Weapons'),
    linkText: t(locale, 'ui', 'Detailed weapons calculation'),
  },
  {
    key: 'talent',
    label: t(locale, 'ui', 'Talents'),
    linkText: t(locale, 'ui', 'Detailed talents calculation'),
  },
  {
    key: 'global',
    label: t(locale, 'ui', 'General'),
    linkText: t(locale, 'ui', 'Detailed calculations'),
  },
];
---

{
  (hasNotes || buildNote?.notes?.length > 0) && (
    <div class="card notes-card">
      <h2>{t(locale, 'ui', 'Notes')}</h2>

      {buildNote && (
        <div>
          {/* Optional external calculation links credited in build-notes.json. */}
          {noteItems.map(
            (item) =>
              buildNote[item.key] && (
                <div>
                  <a href={buildNote[item.key].link} target="_blank">
                    {item.linkText}
                  </a>{' '}
                  - {t(locale, 'ui', 'Thank you to')}{' '}
                  {buildNote[item.key].author}!
                </div>
              ),
          )}

          {buildNote.notes?.length > 0 && (
            <div>
              {/* Build-level editorial notes are already localized and rendered. */}
              {buildNote.notes.map((note: string) => (
                <p set:html={note} />
              ))}
            </div>
          )}
        </div>
      )}

      {hasWeaponsNotes && (
        <div>
          <h3>{t(locale, 'ui', 'Regarding Weapons Choices:')}</h3>

          {notes.weapons.global.map((note: string) => (
            <p set:html={note} />
          ))}

          {notes.weapons.items.map(
            (note: { id: string; name: string; note: string }) => (
              <div
                id={note.id}
                class="note-target"
                set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
              />
            ),
          )}
        </div>
      )}

      {hasArtifactNotes && (
        <div>
          <h3>{t(locale, 'ui', 'Regarding Artifacts Choices:')}</h3>

          {notes.artifacts.global.map((note: string) => (
            <p set:html={note} />
          ))}

          {notes.artifacts.sets.length > 0 && (
            <div>
              <h4>{t(locale, 'ui', 'Sets')}</h4>
              {notes.artifacts.sets.map(
                (note: { id: string; name: string; note: string }) => (
                  <div
                    id={note.id}
                    class="note-target"
                    set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
                  />
                ),
              )}
            </div>
          )}

          {notes.artifacts.mainstats.length > 0 && (
            <div>
              <h4>{t(locale, 'ui', 'Main Stats')}</h4>
              {notes.artifacts.mainstats.map(
                (note: { id: string; name: string; note: string }) => (
                  <div
                    id={note.id}
                    class="note-target"
                    set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
                  />
                ),
              )}
            </div>
          )}

          {notes.artifacts.substats.length > 0 && (
            <div>
              <h4>{t(locale, 'ui', 'Substats')}</h4>
              {notes.artifacts.substats.map(
                (note: { id: string; name: string; note: string }) => (
                  <div
                    id={note.id}
                    class="note-target"
                    set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
                  />
                ),
              )}
            </div>
          )}
        </div>
      )}

      {hasTalentNotes && (
        <div>
          <h3>{t(locale, 'ui', 'Regarding Talents Choices:')}</h3>

          {notes.talents.global.map((note: string) => (
            <p set:html={note} />
          ))}

          {notes.talents.items.map(
            (note: { id: string; name: string; note: string }) => (
              <div
                id={note.id}
                class="note-target"
                set:html={`<span class="element-bold">${note.name}:</span> ${note.note}`}
              />
            ),
          )}
        </div>
      )}
    </div>
  )
}
