---
import { t } from '../utils/i18n';
import {
  formatWeaponPassive,
  type WeaponPassiveValue,
} from '../utils/weapon-passive';

type WeaponInfo = {
  rarity: number;
  passive?: string;
  r1?: WeaponPassiveValue[];
  r2?: WeaponPassiveValue[];
  r3?: WeaponPassiveValue[];
  r4?: WeaponPassiveValue[];
  r5?: WeaponPassiveValue[];
  substat?: string;
  level_1?: {
    base_attack?: number;
    substat_value?: string;
  };
};

type Props = {
  locale: any;
  weapon: {
    name: string;
    rarity: number;
    info?: WeaponInfo;
  };
};

const { locale, weapon } = Astro.props;
const info = weapon.info;
const refinements = [1, 2, 3, 4, 5] as const;

const passivePartsByRefinement = info
  ? refinements.map((refinement) => ({
      refinement,
      parts: formatWeaponPassive(info, refinement).split(/<br\s*\/?>/i),
    }))
  : [];

const substatName = info?.substat
  ? t(locale, 'stat', info.substat, undefined, false)
  : '';
---

<span class="weapon-popover">
  <button class="weapon-popover-trigger" type="button" aria-expanded="false">
    {weapon.name}
  </button>

  {
    info && (
      <span class="weapon-popover-card" role="tooltip">
        <div class="weapon-popover-header">
        <span class="weapon-popover-name">{weapon.name}</span>
        <span class="weapon-popover-rarity">
          {info.rarity} {'\u2605'}
        </span>
        </div>
        <span class="weapon-popover-stat">
          <span>Base ATK</span>
          <strong>{info.level_1?.base_attack}</strong>
        </span>
        {substatName && (
          <span class="weapon-popover-stat">
            <span>{substatName}</span>
            <strong>{info.level_1?.substat_value}</strong>
          </span>
        )}
        <span class="weapon-popover-refinement">
          {refinements.map((refinement) => (
            <button
              class="weapon-popover-refinement-button"
              type="button"
              data-refinement={`r${refinement}`}
              aria-selected={refinement === 1 ? 'true' : 'false'}
            >
              R{refinement}
            </button>
          ))}
        </span>

        <span class="weapon-popover-passive">
          {passivePartsByRefinement.map(({ refinement, parts }) => (
            <span
              class="weapon-popover-passive-refinement"
              data-refinement-panel={`r${refinement}`}
              hidden={refinement !== 1}
              set:html={formatWeaponPassive(info, refinement)}
            />
          ))}
        </span>
      </span>
    )
  }
</span>
