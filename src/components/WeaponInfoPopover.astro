---
import { t } from '../utils/i18n';
import {
  formatWeaponPassive,
  type WeaponPassiveText,
  type WeaponPassiveValue,
} from '../utils/weapon-passive';

type WeaponInfo = {
  rarity: number;
  passive?: WeaponPassiveText;
  r1?: WeaponPassiveValue[];
  r2?: WeaponPassiveValue[];
  r3?: WeaponPassiveValue[];
  r4?: WeaponPassiveValue[];
  r5?: WeaponPassiveValue[];
  substat?: string;
  level_1?: {
    base_attack?: number;
    substat_value?: string;
    level_max?: {
      base_attack?: number;
      substat_value?: string;
    };
  };
};

type Props = {
  locale: any;
  weapon: {
    name: string;
    rarity: number;
    info?: WeaponInfo;
  };
};

const { locale, weapon, lang = 'en' } = Astro.props;
const info = weapon.info;
const refinements = [1, 2, 3, 4, 5] as const;

const passivePartsByRefinement = info
  ? refinements.map((refinement) => ({
      refinement,
      parts: formatWeaponPassive(info, refinement, lang).split(/<br\s*\/?>/i),
    }))
  : [];

const substatName = info?.substat
  ? t(locale, 'stat', info.substat, undefined, false)
  : '';

const formatWeaponStatValue = (
  level1Value?: number | string,
  levelMaxValue?: number | string,
) => {
  if (level1Value === undefined || level1Value === null || level1Value === '') {
    return '';
  }

  if (
    levelMaxValue === undefined ||
    levelMaxValue === null ||
    levelMaxValue === ''
  ) {
    return String(level1Value);
  }

  return `${level1Value} / ${levelMaxValue}`;
};

const baseAttackValue = formatWeaponStatValue(
  info?.level_1?.base_attack,
  info?.level_max?.base_attack,
);
const substatValue = formatWeaponStatValue(
  info?.level_1?.substat_value,
  info?.level_max?.substat_value,
);
---

<span class="weapon-popover">
  <button class="weapon-popover-trigger" type="button" aria-expanded="false">
    {weapon.name}
  </button>

  {
    info && (
      <span class="weapon-popover-card" role="tooltip">
        <div class="weapon-popover-header">
          <span class="weapon-popover-name">{weapon.name}</span>
          <span class="weapon-popover-rarity">
            {info.rarity} {'\u2605'}
          </span>
        </div>
        <span class="weapon-popover-stat">
          <span>Base ATK</span>
          <strong>{baseAttackValue}</strong>
        </span>
        {substatName && (
          <span class="weapon-popover-stat">
            <span>{substatName}</span>
            <strong>{substatValue}</strong>
          </span>
        )}
        <span class="weapon-popover-refinement">
          {refinements.map((refinement) => (
            <button
              class="weapon-popover-refinement-button"
              type="button"
              data-refinement={`r${refinement}`}
              aria-selected={refinement === 1 ? 'true' : 'false'}
            >
              R{refinement}
            </button>
          ))}
        </span>

        <span class="weapon-popover-passive">
          {passivePartsByRefinement.map(({ refinement, parts }) => (
            <span
              class="weapon-popover-passive-refinement"
              data-refinement-panel={`r${refinement}`}
              hidden={refinement !== 1}
              set:html={formatWeaponPassive(info, refinement, lang)}
            />
          ))}
        </span>
      </span>
    )
  }
</span>
