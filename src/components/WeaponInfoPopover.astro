---
import { t } from '../utils/i18n';
import InlineNoteLabel from './InlineNoteLabel.astro';
import {
  formatWeaponPassive,
  type WeaponPassiveText,
  type WeaponPassiveValue,
} from '../utils/weapon-passive';
import { getWeaponSource } from '../utils/weapon-source';
import { resolveWeaponAssetUrlById } from '../utils/item-assets';

type WeaponInfo = {
  rarity: number;
  source?: string;
  passive?: WeaponPassiveText;
  r1?: WeaponPassiveValue[];
  r2?: WeaponPassiveValue[];
  r3?: WeaponPassiveValue[];
  r4?: WeaponPassiveValue[];
  r5?: WeaponPassiveValue[];
  substat?: string;
  level_1?: {
    base_attack?: number;
    substat_value?: string;
  };
  level_max?: {
    base_attack?: number;
    substat_value?: string;
  };
};

type Props = {
  locale: any;
  lang?: string;
  weapon: {
    id?: string;
    name: string;
    rarity: number;
    info?: WeaponInfo;
  };
  noteId?: string;
  hasNote?: boolean;
};

const {
  locale,
  weapon,
  lang = 'en',
  noteId,
  hasNote = false,
} = Astro.props as Props;
const info = weapon.info;
const refinements = [1, 2, 3, 4, 5] as const;

const passivePanels = info
  ? refinements.map((refinement) => ({
      refinement,
      html: formatWeaponPassive(info, refinement, lang),
    }))
  : [];

const substatName = info?.substat
  ? t(locale, 'stat', info.substat, undefined, false)
  : '';

/**
 * Formats weapon stat values as level 1 / max when both are available.
 */
const formatWeaponStatValue = (
  level1Value?: number | string,
  levelMaxValue?: number | string,
) => {
  if (level1Value === undefined || level1Value === null || level1Value === '') {
    return '';
  }

  if (
    levelMaxValue === undefined ||
    levelMaxValue === null ||
    levelMaxValue === ''
  ) {
    return String(level1Value);
  }

  return `${level1Value} / ${levelMaxValue}`;
};

const baseAttackValue = formatWeaponStatValue(
  info?.level_1?.base_attack,
  info?.level_max?.base_attack,
);
const substatValue = formatWeaponStatValue(
  info?.level_1?.substat_value,
  info?.level_max?.substat_value,
);
const source = getWeaponSource(info?.source);
const sourceTranslationKey = `Weapon source ${source}`;
const translatedSourceName = sourceTranslationKey
  ? t(locale, 'ui', sourceTranslationKey, undefined, false)
  : '';
const sourceName =
  translatedSourceName && translatedSourceName !== sourceTranslationKey
    ? translatedSourceName
    : source;
const sourceLabel = t(locale, 'ui', 'Source', undefined, false);
const imageUrl = weapon.id ? resolveWeaponAssetUrlById(weapon.id) : '';
---

<span class="info-popover weapon-popover">
  <span
    class="info-popover-trigger"
    role="button"
    tabindex="0"
    aria-expanded="false"
  >
    <InlineNoteLabel label={weapon.name} noteId={noteId} hasNote={hasNote} />
  </span>

  {
    info && (
      <span class="info-popover-card" role="tooltip">
        <span class={`info-popover-header${imageUrl ? ' has-image' : ''}`}>
          {imageUrl && (
            <span class="info-popover-image weapon-popover-image">
              <img src={imageUrl} alt="" loading="lazy" decoding="async" />
            </span>
          )}
          <span class="info-popover-name">{weapon.name}</span>
          <span class="info-popover-rarity">
            {info.rarity} {'\u2605'}
          </span>
        </span>
        <span class="info-popover-stat">
          <span>Base ATK</span>
          <strong>{baseAttackValue}</strong>
        </span>
        {substatName && (
          <span class="info-popover-stat">
            <span>{substatName}</span>
            <strong>{substatValue}</strong>
          </span>
        )}
        <span class="weapon-popover-refinement">
          {refinements.map((refinement) => (
            <button
              class="weapon-popover-refinement-button"
              type="button"
              data-refinement={`r${refinement}`}
              aria-selected={refinement === 1 ? 'true' : 'false'}
            >
              R{refinement}
            </button>
          ))}
        </span>

        <span class="weapon-popover-passive">
          {passivePanels.map(({ refinement, html }) => (
            <span
              class="weapon-popover-passive-refinement"
              data-refinement-panel={`r${refinement}`}
              hidden={refinement !== 1}
              set:html={html}
            />
          ))}
        </span>
        {sourceName && (
          <span class="weapon-popover-source">
            <span>{sourceLabel}</span>
            <strong>{sourceName}</strong>
          </span>
        )}
      </span>
    )
  }
</span>
