---
import ArtifactSetGroup from './ArtifactSetGroup.astro';
import { t } from '../utils/i18n';
const { artifacts, locale, lang = 'en' } = Astro.props;

type ArtifactSetItem = {
  name: string;
  pieces: number;
  note?: string;
  noteId?: string;
};

type ArtifactSetGroup = {
  items: ArtifactSetItem[];
  choose?: boolean;
};

type ArtifactSetRank = {
  groups: ArtifactSetGroup[];
};

type StatItem = {
  name: string;
  note?: string;
  noteId?: string;
};

type SubstatPriority = StatItem | { items: StatItem[] };

/**
 * Checks whether a substat priority row contains same-rank alternatives.
 *
 * @param item Substat priority entry.
 * @returns True when the entry wraps an `items` array.
 */
const isSubstatGroup = (item: SubstatPriority): item is { items: StatItem[] } =>
  'items' in item;

const artifactSetRanks = artifacts.sets.artifact_sets ?? [];
---

<div class="card">
  <h2>{t(locale, 'ui', 'Artifacts')}</h2>

  {/* SETS */}
  <div class="section">
    <h3>{t(locale, 'ui', 'Sets')}</h3>

    {
      artifactSetRanks.length > 0 &&
        artifactSetRanks.map((rank: ArtifactSetRank, i: number) => (
          <div style="margin-bottom: 10px;">
            <div>
              <strong>{i + 1}.</strong>{' '}
              {rank.groups[0] && (
                <>
                  <span>
                    <ArtifactSetGroup
                      group={rank.groups[0]}
                      locale={locale}
                      lang={lang}
                    />
                  </span>
                </>
              )}
            </div>

            {rank.groups.slice(1).map((group) => (
              <div class="alt">
                &asymp;{' '}
                <span>
                  <ArtifactSetGroup group={group} locale={locale} lang={lang} />
                </span>
              </div>
            ))}
          </div>
        ))
    }

    {
      artifacts.sets.conditional?.length > 0 && (
        <div style={artifactSetRanks.length > 0 ? 'margin-top: 14px;' : ''}>
          <div class="bold">{t(locale, 'ui', 'Conditional (See Notes):')}</div>

          {artifacts.sets.conditional.map((group: ArtifactSetGroup) => (
            <div>
              <ArtifactSetGroup group={group} locale={locale} lang={lang} />
            </div>
          ))}
        </div>
      )
    }
  </div>

  {/* MAIN STATS */}
  <div class="section">
    <h3>{t(locale, 'ui', 'Main Stats')}</h3>

    <div>
      <strong>{t(locale, 'ui', 'Sands')}:</strong>{' '}
      {
        artifacts.mainstats.main_stats.sands.map(
          (stat: StatItem, statIndex: number) => (
            <>
              {statIndex > 0 && ' / '}
              {stat.name}
              {stat.noteId ? (
                <a class="note-link" href={`#${stat.noteId}`}>
                  *
                </a>
              ) : stat.note ? (
                '*'
              ) : (
                ''
              )}
            </>
          ),
        )
      }
    </div>

    <div>
      <strong>{t(locale, 'ui', 'Goblet')}:</strong>{' '}
      {
        artifacts.mainstats.main_stats.goblet.map(
          (stat: StatItem, statIndex: number) => (
            <>
              {statIndex > 0 && ' / '}
              {stat.name}
              {stat.noteId ? (
                <a class="note-link" href={`#${stat.noteId}`}>
                  *
                </a>
              ) : stat.note ? (
                '*'
              ) : (
                ''
              )}
            </>
          ),
        )
      }
    </div>

    <div>
      <strong>{t(locale, 'ui', 'Circlet')}:</strong>{' '}
      {
        artifacts.mainstats.main_stats.circlet.map(
          (stat: StatItem, statIndex: number) => (
            <>
              {statIndex > 0 && ' / '}
              {stat.name}
              {stat.noteId ? (
                <a class="note-link" href={`#${stat.noteId}`}>
                  *
                </a>
              ) : stat.note ? (
                '*'
              ) : (
                ''
              )}
            </>
          ),
        )
      }
    </div>
  </div>

  {/* SUBSTATS */}
  <div class="section">
    <h3>{t(locale, 'ui', 'Substats')}</h3>

    {
      artifacts.substats.substats_priority.map(
        (stat: SubstatPriority, i: number) =>
          isSubstatGroup(stat) ? (
            <div>
              <div>
                <strong>{i + 1}.</strong>{' '}
                {stat.items[0] && (
                  <>
                    {stat.items[0].name}
                    {stat.items[0].noteId ? (
                      <a class="note-link" href={`#${stat.items[0].noteId}`}>
                        *
                      </a>
                    ) : stat.items[0].note ? (
                      '*'
                    ) : (
                      ''
                    )}
                  </>
                )}
              </div>
              {stat.items.slice(1).map((item) => (
                <div class="alt">
                  &asymp; {item.name}
                  {item.noteId ? (
                    <a class="note-link" href={`#${item.noteId}`}>
                      *
                    </a>
                  ) : item.note ? (
                    '*'
                  ) : (
                    ''
                  )}
                </div>
              ))}
            </div>
          ) : (
            <div>
              <strong>{i + 1}.</strong> {stat.name}
              {stat.noteId ? (
                <a class="note-link" href={`#${stat.noteId}`}>
                  *
                </a>
              ) : stat.note ? (
                '*'
              ) : (
                ''
              )}
            </div>
          ),
      )
    }
  </div>
</div>

<script>
  import '../scripts/info-popover';
</script>
