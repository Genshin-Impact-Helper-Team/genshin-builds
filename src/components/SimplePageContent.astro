---
import { marked } from 'marked';
import changelog from '../content/site/changelog.json';
import credits from '../content/site/credits.json';
import faq from '../content/site/faq.json';
import { t } from '../utils/i18n';

type PageKind = 'changelog' | 'credits' | 'faq';
type LocalizedText = {
  en: string;
  [lang: string]: string;
};
type FaqData = {
  intro: LocalizedText;
  items: {
    question: LocalizedText;
    answer: LocalizedText;
  }[];
};
type ChangelogData = {
  groups: {
    version: string;
    entries: {
      date: string;
      changes: string;
      appliedBy?: string;
    }[];
  }[];
};
type CreditsData = {
  surveyUrl: string;
  translators: Record<string, string[]>;
  sections: {
    title: string;
    names: string[];
  }[];
};

const {
  kind,
  lang = 'en',
  locale,
} = Astro.props as {
  kind: PageKind;
  lang?: string;
  locale?: any;
};

const faqData = faq as FaqData;
const changelogData = changelog as ChangelogData;
const creditsData = credits as CreditsData;

const translators = creditsData.translators[lang] ?? [];
const localized = (value: LocalizedText) => value[lang] ?? value.en;
const renderText = (value: string) =>
  marked.parse(value, { breaks: true }) as string;
---

{
  kind === 'faq' && (
    <>
      <section class="card faq-card">
        <div set:html={renderText(localized(faqData.intro))} />
      </section>

      <section class="faq-list">
        {faqData.items.map((item) => (
          <details class="card faq-item">
            <summary>{localized(item.question)}</summary>
            <div set:html={renderText(localized(item.answer))} />
          </details>
        ))}
      </section>
    </>
  )
}

{
  kind === 'changelog' && (
    <section class="changelog-list" aria-label="Document changelog">
      {changelogData.groups.map((group, index) => (
        <section
          class="changelog-version"
          aria-labelledby={`changelog-version-${index}`}
        >
          <h2 id={`changelog-version-${index}`}>{group.version}</h2>
          <div class="changelog-version-entries">
            {group.entries.map((entry) => (
              <article class="card changelog-card">
                <time>{entry.date}</time>
                <p>{entry.changes}</p>
                {entry.appliedBy && (
                  <p class="changelog-author">Applied by {entry.appliedBy}</p>
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </section>
  )
}

{
  kind === 'credits' && locale && (
    <>
      <section class="card credits-card credits-legal-card">
        <h2>{t(locale, 'ui', 'Legal Notice', undefined, false)}</h2>
        <p>{t(locale, 'ui', 'Legal notice unofficial', undefined, false)}</p>
        <p>{t(locale, 'ui', 'Legal notice ownership', undefined, false)}</p>
        <p class="credits-legal-declaration">
          © All rights reserved by COGNOSPHERE. Other properties belong to their
          respective owners.
        </p>
        <p>
          {t(locale, 'ui', 'Legal notice unpublished', undefined, false)}{' '}
          <a
            href="https://www.hoyolab.com/article/143107"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t(locale, 'ui', 'Legal FAQ', undefined, false)}
          </a>
          .
        </p>
      </section>

      <section class="card credits-card">
        <p>
          {t(locale, 'ui', 'Credits feedback')}
          <a href={creditsData.surveyUrl} target="_blank">
            {t(locale, 'ui', 'GI Helper Team survey')}
          </a>
          .
        </p>
      </section>

      {translators.length > 0 && (
        <section class="card credits-card">
          <h2>{t(locale, 'ui', 'Translator')}</h2>
          <ul class="credits-list">
            {translators.map((name) => (
              <li>{name}</li>
            ))}
          </ul>
        </section>
      )}

      {creditsData.sections.map((section) => (
        <section class="card credits-card">
          <h2>{t(locale, 'ui', section.title)}</h2>
          <ul class="credits-list">
            {section.names.map((name) => (
              <li>{name}</li>
            ))}
          </ul>
        </section>
      ))}
    </>
  )
}
