---
import { t } from '../utils/i18n';

type TalentItem = {
  name: string;
  note?: string;
  noteId?: string;
};

type TalentPriority = {
  items: TalentItem[];
  approx?: boolean;
};

type TalentRecommendations = {
  talents: TalentPriority[];
};

const { talents, locale } = Astro.props as {
  talents: TalentRecommendations;
  locale: any;
};

const hasNoteMarker = (item: TalentItem) => item.noteId || item.note;
const talentRows = talents.talents.map(
  (talent: TalentPriority, index: number) => ({
    rank: index + 1,
    mainItems: talent.approx ? talent.items.slice(0, 1) : talent.items,
    alternativeItems: talent.approx ? talent.items.slice(1) : [],
  }),
);
---

<div class="card">
  <h2>{t(locale, 'ui', 'Talents')}</h2>

  {
    talentRows.map((talent) => (
      <div style="margin-bottom: 10px;">
        <div>
          <strong class="accent-text">{talent.rank}.</strong>{' '}
          <span>
            {talent.mainItems.map((item, itemIndex) => (
              <>
                {itemIndex > 0 && ' = '}
                {item.name}
                {item.noteId ? (
                  <a class="note-link" href={`#${item.noteId}`}>
                    *
                  </a>
                ) : hasNoteMarker(item) ? (
                  '*'
                ) : (
                  ''
                )}
              </>
            ))}
          </span>
        </div>

        {talent.alternativeItems.map((item) => (
          <div class="alt">
            &asymp; {item.name}
            {item.noteId ? (
              <a class="note-link" href={`#${item.noteId}`}>
                *
              </a>
            ) : hasNoteMarker(item) ? (
              '*'
            ) : (
              ''
            )}
          </div>
        ))}
      </div>
    ))
  }
</div>
