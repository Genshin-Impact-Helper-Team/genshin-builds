---
import { t } from '../utils/i18n';
import InlineNoteLabel from './InlineNoteLabel.astro';

type TalentItem = {
  name: string;
  note?: string;
  noteId?: string;
};

type TalentPriority = {
  items: TalentItem[];
  approx?: boolean;
};

type TalentRecommendations = {
  talents: TalentPriority[];
};

const { talents, locale } = Astro.props as {
  talents: TalentRecommendations;
  locale: any;
};

const hasNoteMarker = (item: TalentItem) => item.noteId || item.note;
const talentRows = talents.talents.map(
  (talent: TalentPriority, index: number) => ({
    rank: index + 1,
    mainItems: talent.approx ? talent.items.slice(0, 1) : talent.items,
    alternativeItems: talent.approx ? talent.items.slice(1) : [],
  }),
);
---

<div class="card recommendation-card talent-card">
  <h2>{t(locale, 'ui', 'Talents')}</h2>

  <div class="recommendation-card-body">
    <div class="rank-list">
      {
        talentRows.map((talent) => (
          <div class="rank-group">
            <div class="rank-row">
              <strong class="rank-number">{talent.rank}</strong>
              <span class="rank-content">
                {talent.mainItems.map((item, itemIndex) => (
                  <>
                    {itemIndex > 0 && ' = '}
                    <InlineNoteLabel
                      label={item.name}
                      noteId={item.noteId}
                      hasNote={Boolean(hasNoteMarker(item))}
                    />
                  </>
                ))}
              </span>
            </div>

            {talent.alternativeItems.map((item) => (
              <div class="rank-row alt">
                <span class="rank-approx">&asymp;</span>
                <span class="rank-content">
                  <InlineNoteLabel
                    label={item.name}
                    noteId={item.noteId}
                    hasNote={Boolean(hasNoteMarker(item))}
                  />
                </span>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</div>
