---
import { t } from '../utils/i18n';
import ArtifactSetInfoPopover from './ArtifactSetInfoPopover.astro';

type ArtifactSetItem = {
  name: string;
  pieces: number;
  note?: string;
  noteId?: string;
  id?: string;
  info?: {
    rarity: number;
    '1p'?: { en?: string; [lang: string]: string | undefined };
    '2p'?: { en?: string; [lang: string]: string | undefined };
    '4p'?: { en?: string; [lang: string]: string | undefined };
  };
};

type ArtifactSetGroup = {
  items?: ArtifactSetItem[];
  choose?: boolean;
  choices?: { items: ArtifactSetItem[] }[];
};

type ArtifactSetRow = {
  items?: ArtifactSetItem[];
  alt?: boolean;
  bold?: boolean;
  label?: string;
  prefix?: string;
  chooseOne?: boolean;
};

const {
  group,
  locale,
  lang = 'en',
} = Astro.props as {
  group: ArtifactSetGroup;
  locale: any;
  lang?: string;
};

const groupItems = group.items ?? [];
const rows: ArtifactSetRow[] = group.choose
  ? [
      ...groupItems.map((item, index) => ({
        items: [item],
        alt: index > 0,
      })),
      {
        alt: true,
        bold: true,
        label: t(locale, 'ui', 'Choose Two'),
      },
    ]
  : group.choices
    ? group.choices.map((choice, index) => ({
        items: choice.items,
        alt: index > 0,
        prefix: index > 0 ? '& ' : '',
        chooseOne: true,
      }))
    : [{ items: groupItems }];
---

{
  /* Choose-two groups render extra items as `.alt` rows to match approximate ties. */
}
{
  rows.map((row) => {
    const content = row.label ? (
      row.label
    ) : (
      <>
        {row.prefix}
        {row.items?.map((item, itemIndex) => (
          <>
            {itemIndex > 0 && ' / '}
            <span class="inline-info-label artifact-info-label">
              <ArtifactSetInfoPopover
                artifact={item}
                suffix={`(${item.pieces})`}
                lang={lang}
              />
            </span>
            {item.noteId ? (
              <a class="note-link" href={`#${item.noteId}`}>
                *
              </a>
            ) : item.note ? (
              '*'
            ) : (
              ''
            )}
          </>
        ))}
        {row.chooseOne && (row.items?.length ?? 0) > 0 && (
          <>
            {' '}
            <span class="bold">{t(locale, 'ui', 'Choose One')}</span>
          </>
        )}
      </>
    );

    return row.alt ? (
      <div class={row.bold ? 'alt bold' : 'alt'}>{content}</div>
    ) : (
      <>{content}</>
    );
  })
}
