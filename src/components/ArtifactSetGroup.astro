---
import { t } from '../utils/i18n';
import ArtifactSetInfoPopover from './ArtifactSetInfoPopover.astro';

type ArtifactSetItem = {
  name: string;
  pieces: number;
  note?: string;
  noteId?: string;
  id?: string;
  info?: {
    rarity: number;
    '1p'?: { en?: string; [lang: string]: string | undefined };
    '2p'?: { en?: string; [lang: string]: string | undefined };
    '4p'?: { en?: string; [lang: string]: string | undefined };
  };
};

type ArtifactSetGroup = {
  items: ArtifactSetItem[];
  choose?: boolean;
};

const {
  group,
  locale,
  lang = 'en',
} = Astro.props as {
  group: ArtifactSetGroup;
  locale: any;
  lang?: string;
};
---

{
  /* Choose-two groups render extra items as `.alt` rows to match approximate ties. */
}
{
  group.choose ? (
    <>
      {group.items[0] && (
        <>
          <span class="inline-info-label">
            <ArtifactSetInfoPopover artifact={group.items[0]} lang={lang} />
            <span class="bold">({group.items[0].pieces})</span>
          </span>
          {group.items[0].noteId ? (
            <a class="note-link" href={`#${group.items[0].noteId}`}>
              *
            </a>
          ) : group.items[0].note ? (
            '*'
          ) : (
            ''
          )}
        </>
      )}
      {group.items.slice(1).map((item) => (
        <div class="alt">
          <span class="inline-info-label">
            <ArtifactSetInfoPopover artifact={item} lang={lang} />
            <span class="bold">({item.pieces})</span>
          </span>
          {item.noteId ? (
            <a class="note-link" href={`#${item.noteId}`}>
              *
            </a>
          ) : item.note ? (
            '*'
          ) : (
            ''
          )}
        </div>
      ))}
      <div class="alt bold">{t(locale, 'ui', 'Choose Two')}</div>
    </>
  ) : (
    <>
      {group.items.map((item, itemIndex) => (
        <>
          {itemIndex > 0 && ' / '}
          <span class="inline-info-label">
            <ArtifactSetInfoPopover artifact={item} lang={lang} />
            <span class="bold">({item.pieces})</span>
          </span>
          {item.noteId ? (
            <a class="note-link" href={`#${item.noteId}`}>
              *
            </a>
          ) : item.note ? (
            '*'
          ) : (
            ''
          )}
        </>
      ))}
    </>
  )
}
