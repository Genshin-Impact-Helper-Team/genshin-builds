---
import { t } from '../utils/i18n';
import ArtifactSetInfoPopover from './ArtifactSetInfoPopover.astro';

type ArtifactSetItem = {
  name: string;
  pieces: number;
  note?: string;
  noteId?: string;
  id?: string;
  info?: {
    rarity: number;
    '1p'?: { en?: string; [lang: string]: string | undefined };
    '2p'?: { en?: string; [lang: string]: string | undefined };
    '4p'?: { en?: string; [lang: string]: string | undefined };
  };
};

type ArtifactSetGroup = {
  items?: ArtifactSetItem[];
  choose?: boolean;
  choices?: ArtifactChoicePool[];
};

type ArtifactChoicePool = {
  items: ArtifactSetItem[];
};

type ArtifactSetRow = {
  items?: ArtifactSetItem[];
  choicePools?: ArtifactChoicePool[];
  alt?: boolean;
  bold?: boolean;
  label?: string;
  prefix?: string;
  chooseOne?: boolean;
};

const {
  group,
  locale,
  lang = 'en',
} = Astro.props as {
  group: ArtifactSetGroup;
  locale: any;
  lang?: string;
};

const groupItems = group.items ?? [];
const rows: ArtifactSetRow[] = group.choose
  ? [
      ...groupItems.map((item, index) => ({
        items: [item],
        alt: index > 0,
      })),
      {
        alt: true,
        bold: true,
        label: t(locale, 'ui', 'Choose Two'),
      },
    ]
  : group.choices && groupItems.length > 0
    ? [{ items: groupItems, choicePools: group.choices }]
    : group.choices
      ? group.choices.map((choice, index) => ({
          items: choice.items,
          alt: index > 0,
          prefix: index > 0 ? 'and ' : '',
          chooseOne: true,
        }))
      : [{ items: groupItems }];
---

{
  /* Choose-two groups render extra items as `.alt` rows to match approximate ties. */
}
{
  rows.map((row) => {
    const content = row.label ? (
      <span class="accent-text bold">{row.label}</span>
    ) : (
      <>
        {row.prefix && <span class="accent-text">{row.prefix}</span>}
        {row.items?.map((item, itemIndex) => (
          <>
            {itemIndex > 0 && ' / '}
            <span class="inline-info-label artifact-info-label">
              <ArtifactSetInfoPopover
                artifact={item}
                suffix={`(${item.pieces})`}
                lang={lang}
                noteId={item.noteId}
                hasNote={Boolean(item.noteId || item.note)}
              />
            </span>
          </>
        ))}
        {row.choicePools?.map((choice) => (
          <>
            {' '}
            <span class="accent-text">
              {t(locale, 'ui', 'and', undefined, false)}
            </span>{' '}
            {choice.items.map((item, itemIndex) => (
              <>
                {itemIndex > 0 && ' / '}
                <span class="inline-info-label artifact-info-label">
                  <ArtifactSetInfoPopover
                    artifact={item}
                    suffix={`(${item.pieces})`}
                    lang={lang}
                    noteId={item.noteId}
                    hasNote={Boolean(item.noteId || item.note)}
                  />
                </span>
              </>
            ))}
            {choice.items.length > 0 && (
              <>
                {' '}
                <span class="accent-text bold">
                  {t(locale, 'ui', 'Choose One')}
                </span>
              </>
            )}
          </>
        ))}
        {row.chooseOne && (row.items?.length ?? 0) > 0 && (
          <>
            {' '}
            <span class="accent-text bold">
              {t(locale, 'ui', 'Choose One')}
            </span>
          </>
        )}
      </>
    );

    return row.alt ? (
      <div class={row.bold ? 'alt bold' : 'alt'}>{content}</div>
    ) : (
      <>{content}</>
    );
  })
}
