---
import '../styles/header.css';
import { t } from '../utils/i18n';
import { languages } from '../utils/languages';
import { localizedPath } from '../utils/paths';
import { getSideMenuData } from '../utils/side-menu';

type Props = {
  locale: any;
  lang?: string;
  character?: string;
  page?: string;
};

const { locale, lang, character, page } = Astro.props as Props;

const currentLang = lang || 'en';
const menuElements = getSideMenuData(locale);
---

<header class="site-header">
  <div class="header-content">
    <div class="header-brand">
      <button
        class="menu-toggle"
        type="button"
        aria-label="Open character menu"
        aria-expanded="false"
        aria-controls="side-menu"
        data-menu-open
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <a
        href={localizedPath(currentLang)}
        class="logo-link"
        aria-label="Genshin Builds home"
      >
        <h1>Genshin Builds</h1>
      </a>
    </div>

    <nav class="language-switcher">
      <span class="language-label">{t(locale, 'ui', 'Language')}:</span>
      <select
        class="language-select"
        id="language-select"
        value={currentLang}
        data-character={character}
        data-page={page}
      >
        {
          languages.map((language) => (
            <option
              value={language.code}
              selected={language.code === currentLang}
            >
              {language.name}
            </option>
          ))
        }
      </select>
    </nav>
  </div>

  <div class="menu-backdrop" data-menu-close></div>
  <aside class="side-menu" id="side-menu" aria-label="Character menu">
    <div class="side-menu-header">
      <button
        class="menu-close"
        type="button"
        aria-label="Close character menu"
        data-menu-close
      >
        &times;
      </button>
    </div>

    <nav class="side-menu-nav">
      <a class="side-menu-link" href={localizedPath(currentLang)}>
        {t(locale, 'ui', 'Home')}
      </a>
      <a class="side-menu-link" href={localizedPath(currentLang, 'faq')}>
        {t(locale, 'ui', 'FAQ')}
      </a>
      {
        menuElements.map((element) => (
          <details class={`element-group ${element.element}`}>
            <summary>{element.name}</summary>
            <div class="rarity-groups">
              {element.rarities.map((rarity) => (
                <details class="rarity-group">
                  <summary>{rarity.label}</summary>
                  <ul>
                    {rarity.characters.map((character) => (
                      <li>
                        <a href={localizedPath(currentLang, character.slug)}>
                          {character.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          </details>
        ))
      }
    </nav>
  </aside>
</header>

<script>
  import '../scripts/header';
</script>
