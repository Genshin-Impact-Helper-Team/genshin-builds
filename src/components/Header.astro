---
import '../styles/header.css';
import { t } from '../utils/i18n';
import { languages } from '../utils/languages';
import { localizedPath } from '../utils/paths';

type Props = {
  locale: any;
  lang?: string;
  character?: string;
  page?: string;
};

const { locale, lang, character, page } = Astro.props as Props;

const currentLang = lang || 'en';
const primaryLinks = [
  {
    href: localizedPath(currentLang),
    label: t(locale, 'ui', 'Characters', undefined, false),
    isCurrent: !page,
  },
  {
    href: localizedPath(currentLang, 'weapons'),
    label: t(locale, 'ui', 'Weapons', undefined, false),
    isCurrent: page === 'weapons',
  },
  {
    href: localizedPath(currentLang, 'artifacts'),
    label: t(locale, 'ui', 'Artifacts Sets', undefined, false),
    isCurrent: page === 'artifacts',
  },
];
const infoLinks = [
  {
    href: localizedPath(currentLang, 'faq'),
    label: t(locale, 'ui', 'FAQ', undefined, false),
    isCurrent: page === 'faq',
  },
  {
    href: localizedPath(currentLang, 'credits'),
    label: t(locale, 'ui', 'Credits', undefined, false),
    isCurrent: page === 'credits',
  },
  {
    href: localizedPath(currentLang, 'changelog'),
    label: t(locale, 'ui', 'Changelog', undefined, false),
    isCurrent: page === 'changelog',
  },
];
const isInfoCurrent = infoLinks.some((link) => link.isCurrent);
---

<header class="site-header">
  <div class="navbar">
    <a
      href={localizedPath(currentLang)}
      class="logo-link"
      aria-label="Genshin Builds home"
    >
      <span>Genshin Builds</span>
    </a>

    <div class="nav-panel" id="primary-navigation">
      <nav class="primary-nav" aria-label="Main navigation">
        {
          primaryLinks.map((link) => (
            <a
              class="nav-link"
              href={link.href}
              aria-current={link.isCurrent ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }

        <details class={`nav-dropdown${isInfoCurrent ? ' is-current' : ''}`}>
          <summary class="nav-link">
            {t(locale, 'ui', 'Information', undefined, false)}
            <span class="dropdown-chevron" aria-hidden="true"></span>
          </summary>
          <div class="dropdown-menu">
            {
              infoLinks.map((link) => (
                <a
                  class="dropdown-link"
                  href={link.href}
                  aria-current={link.isCurrent ? 'page' : undefined}
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </details>
      </nav>
    </div>

    <div class="navbar-actions">
      <div class="language-switcher">
        <label class="language-label" for="language-select">
          {t(locale, 'ui', 'Language')}:
        </label>
        <select
          class="language-select"
          id="language-select"
          aria-label={t(locale, 'ui', 'Language')}
          value={currentLang}
          data-character={character}
          data-page={page}
        >
          {
            languages.map((language) => (
              <option
                value={language.code}
                selected={language.code === currentLang}
              >
                {language.name}
              </option>
            ))
          }
        </select>
      </div>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="primary-navigation"
        data-nav-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<script>
  import '../scripts/header';
</script>
