---
import '../styles/header.css';
import { t } from '../utils/i18n';
import { languages } from '../utils/languages';
import { localizedPath } from '../utils/paths';
import { getSideMenuData } from '../utils/side-menu';

type Props = {
  locale: any;
  lang?: string;
  character?: string;
  page?: string;
};

const { locale, lang, character, page } = Astro.props as Props;

const currentLang = lang || 'en';
const menuElements = getSideMenuData(locale);
const isHomePage = !character && !page;
const browseLinks = [
  {
    href: localizedPath(currentLang),
    label: t(locale, 'ui', 'Home', undefined, false),
    isCurrent: isHomePage,
  },
  {
    href: localizedPath(currentLang, 'weapons'),
    label: t(locale, 'ui', 'Weapons', undefined, false),
    isCurrent: page === 'weapons',
  },
];
const infoLinks = [
  {
    href: localizedPath(currentLang, 'faq'),
    label: t(locale, 'ui', 'FAQ', undefined, false),
    isCurrent: page === 'faq',
  },
  {
    href: localizedPath(currentLang, 'credits'),
    label: t(locale, 'ui', 'Credits', undefined, false),
    isCurrent: page === 'credits',
  },
  {
    href: localizedPath(currentLang, 'changelog'),
    label: t(locale, 'ui', 'Changelog', undefined, false),
    isCurrent: page === 'changelog',
  },
];
---

<header class="site-header">
  <div class="header-content">
    <div class="header-brand">
      <button
        class="menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="side-menu"
        data-menu-open
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <a
        href={localizedPath(currentLang)}
        class="logo-link"
        aria-label="Genshin Builds home"
      >
        <h1>Genshin Builds</h1>
      </a>
    </div>

    <nav class="language-switcher">
      <span class="language-label">{t(locale, 'ui', 'Language')}:</span>
      <select
        class="language-select"
        id="language-select"
        value={currentLang}
        data-character={character}
        data-page={page}
      >
        {
          languages.map((language) => (
            <option
              value={language.code}
              selected={language.code === currentLang}
            >
              {language.name}
            </option>
          ))
        }
      </select>
    </nav>
  </div>

  <div class="menu-backdrop" data-menu-close></div>
  <aside class="side-menu" id="side-menu" aria-label="Site menu">
    <div class="side-menu-header">
      <button
        class="menu-close"
        type="button"
        aria-label="Close menu"
        data-menu-close
      >
        &times;
      </button>
    </div>

    <nav class="side-menu-nav">
      <section class="side-menu-section" aria-labelledby="side-menu-browse">
        <h2 id="side-menu-browse">
          {t(locale, 'ui', 'Browse', undefined, false)}
        </h2>
        <div class="side-menu-links">
          {
            browseLinks.map((link) => (
              <a
                class="side-menu-link"
                href={link.href}
                aria-current={link.isCurrent ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </section>

      <section class="side-menu-section" aria-labelledby="side-menu-info">
        <h2 id="side-menu-info">
          {t(locale, 'ui', 'Information', undefined, false)}
        </h2>
        <div class="side-menu-links">
          {
            infoLinks.map((link) => (
              <a
                class="side-menu-link"
                href={link.href}
                aria-current={link.isCurrent ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </section>

      <details class="side-menu-section character-index">
        <summary>{t(locale, 'ui', 'Characters', undefined, false)}</summary>
        <div class="character-index-groups">
          {
            menuElements.map((element) => (
              <details class={`element-group ${element.element}`}>
                <summary>{element.name}</summary>
                <div class="rarity-groups">
                  {element.rarities.map((rarity) => (
                    <details class="rarity-group">
                      <summary>{rarity.label}</summary>
                      <ul>
                        {rarity.characters.map((character) => (
                          <li>
                            <a
                              href={localizedPath(currentLang, character.slug)}
                            >
                              {character.name}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </details>
                  ))}
                </div>
              </details>
            ))
          }
        </div>
      </details>
    </nav>
  </aside>
</header>

<script>
  import '../scripts/header';
</script>
