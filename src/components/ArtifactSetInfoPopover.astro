---
import InlineNoteLabel from './InlineNoteLabel.astro';

type LocalizedArtifactEffect = {
  en?: string;
  [lang: string]: string | undefined;
};

type ArtifactSetInfo = {
  rarity: number;
  '1p'?: LocalizedArtifactEffect;
  '2p'?: LocalizedArtifactEffect;
  '4p'?: LocalizedArtifactEffect;
};

type Props = {
  artifact: {
    name: string;
    id?: string;
    info?: ArtifactSetInfo;
  };
  suffix?: string;
  lang?: string;
  noteId?: string;
  hasNote?: boolean;
};

const {
  artifact,
  suffix = '',
  lang = 'en',
  noteId,
  hasNote = false,
} = Astro.props as Props;
const info = artifact.info;

/**
 * Selects the localized set effect with English fallback.
 */
const localizedEffect = (effect?: LocalizedArtifactEffect) =>
  effect?.[lang] ?? effect?.en ?? '';

const effects = info
  ? [
      { label: '1P', value: localizedEffect(info['1p']) },
      { label: '2P', value: localizedEffect(info['2p']) },
      { label: '4P', value: localizedEffect(info['4p']) },
    ].filter((effect) => effect.value)
  : [];
---

{
  info ? (
    <span class="info-popover artifact-popover">
      <span
        class="info-popover-trigger artifact-popover-trigger"
        role="button"
        tabindex="0"
        aria-expanded="false"
      >
        <InlineNoteLabel
          label={artifact.name}
          noteId={noteId}
          hasNote={hasNote}
        />
        {suffix && (
          <span class="artifact-piece-suffix">
            {'\u00a0'}
            {suffix}
          </span>
        )}
      </span>

      <span class="info-popover-card artifact-popover-card" role="tooltip">
        <span class="info-popover-header">
          <span class="info-popover-name">{artifact.name}</span>
          <span class="info-popover-rarity">
            {info.rarity} {'\u2605'}
          </span>
        </span>

        {effects.map((effect) => (
          <span class="info-popover-stat artifact-popover-effect">
            <span>{effect.label}</span>
            <strong>{effect.value}</strong>
          </span>
        ))}
      </span>
    </span>
  ) : (
    <>
      <InlineNoteLabel
        label={artifact.name}
        noteId={noteId}
        hasNote={hasNote}
      />
      {suffix && (
        <span class="artifact-piece-suffix">
          {'\u00a0'}
          {suffix}
        </span>
      )}
    </>
  )
}
